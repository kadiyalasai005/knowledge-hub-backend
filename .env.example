# .env.example
PROJECT_NAME="Knowledge Hub Backend"
API_V1_STR="/api/v1"

# Database Configuration
POSTGRES_SERVER=db
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=knowledge_hub_db
# DATABASE_URL will be constructed in config.py

# Vector DB Configuration
VECTOR_STORE_PATH=./data/vector_store
CHROMA_COLLECTION_NAME=knowledge_base

# Redis (Celery Broker) Configuration
REDIS_HOST=redis
REDIS_PORT=6379
# CELERY_BROKER_URL will be constructed in config.py
# CELERY_RESULT_BACKEND will be constructed in config.py

# Security Configuration
SECRET_KEY="replace_with_a_long_random_secret_key_generated_with_openssl_rand_-hex_32"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Google Cloud Configuration
GCP_PROJECT_ID=your-gcp-project-id
DOCUMENT_AI_PROCESSOR_ID=your-docai-processor-id
DOCUMENT_AI_LOCATION=us
GCS_BUCKET_NAME=your-gcs-bucket-name

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key

# AI/ML Configuration
EMBEDDING_MODEL=text-embedding-004
LLM_MODEL=gemini-1.5-flash

# Processing Configuration
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
TOP_K_RESULTS=3

# CORS Configuration
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
