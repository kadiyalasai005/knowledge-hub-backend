# .env.example
PROJECT_NAME="Knowledge Hub Backend"
API_V1_STR="/api/v1"

# Add any other non-secret defaults here if needed
# We will add Database, API Keys etc later
# --- Redis (Celery Broker) ---
REDIS_HOST=redis
REDIS_PORT=6379
# CELERY_BROKER_URL will be constructed in config.py
# CELERY_RESULT_BACKEND will be constructed in config.py

# --- Security ---
SECRET_KEY="replace_with_a_long_random_secret_key_generated_with_openssl_rand_-hex_32"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256